<?xml version="1.0"?>
<robot name="qbot_platform">

  <!-- ========================= Materials ========================= -->
  <material name="Black">
    <color rgba="0.0 0.0 0. 1.0"/>
  </material>

  <material name="Red">
    <color rgba="0.8 0.0 0.0 1.0"/>
  </material>

  <material name="Blue">
    <color rgba="0.0 0.0 0.8 1.0"/>
  </material>

  <!-- ========================= Base Links ========================= -->
  <link name="base_footprint"/>

  <joint name="base_link_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.112" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://qbot_platform/meshes/qbot_platform_body.stl"
              scale="1 1 1"/>

      </geometry>
      <material name="Black"/>
    </visual>

    <visual>
      <origin xyz="-0.046 0.002 -0.0838" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://qbot_platform/meshes/qbot_platform_body_red.stl"
              scale="0.978 0.978 0.978"/>
      </geometry>
      <material name="Red"/>
    </visual>

    <!-- Collision surface definitions -->
    <!-- front -->
    <collision>
      <origin xyz="0.2175 0.13057 0" rpy="0 0 -1.0472"/>
      <geometry>
      <box size="0.3 0.01 0.18"/>
      </geometry>
    </collision>

    <collision>
      <origin xyz="0.2175 -0.13057 0" rpy="0 0 1.0472"/>
      <geometry>
      <box size="0.3 0.01 0.18"/>
      </geometry>
    </collision>
    <!-- middle -->

    <collision>
      <origin xyz="0 0.26 0" rpy="0 0 3.1415"/>
      <geometry>
      <box size="0.3 0.01 0.18"/>
      </geometry>
    </collision>

    <collision>
      <origin xyz="0 -0.26 0" rpy="0 0 3.1415"/>
      <geometry>
      <box size="0.3 0.01 0.18"/>
      </geometry>
    </collision>


    <!-- rear -->
    <collision>
      <origin xyz="-0.2175 0.13057 0" rpy="0 0 1.0472"/>
      <geometry>
      <box size="0.3 0.01 0.18"/>
      </geometry>
    </collision>

    <collision>
      <origin xyz="-0.2175 -0.13057 0" rpy="0 0 -1.0472"/>
      <geometry>
      <box size="0.3 0.01 0.18"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="20.87"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0" izz="0.8122"/>
    </inertial>
  </link>

  <!-- ========================= Sensors ========================= -->
  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 -0.04" rpy="0 0 0"/>
  </joint>

  <link name="lidar_link"/>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.221 0 0.1" rpy="0 0 0"/>
  </joint>

  <link name="realsense_depth_link"/>
  <joint name="realsense_depth_joint" type="fixed">
    <parent link="base_link"/>
    <child link="realsense_depth_link"/>
    <origin xyz="0.261 0 0.03" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <link name="realsense_rgb_link"/>
  <joint name="realsense_rgb_joint" type="fixed">
    <parent link="base_link"/>
    <child link="realsense_rgb_link"/>
    <origin xyz="0.261 0.033 0.03" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <link name="downward_camera_link"/>
  <joint name="downward_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="downward_camera_link"/>
    <origin xyz="0.03 0 -0.05" rpy="3.14159 0 -1.5708"/>
  </joint>
  
  <!-- ========================= Wheels ========================= -->
  <joint name="left_wheel_joint" type="revolute">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.1965 -0.0605" rpy="-1.57 -1.57 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1e16" upper="1e16" effort="300" velocity="2"/>
  </joint>

  <link name="left_wheel">
    <visual>
      <geometry>
        <mesh filename="package://qbot_platform/meshes/qbot_platform_wheel.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="Red"/>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.045" length="0.025" />
      </geometry>
    </collision>

    <inertial>
      <mass value="0.005"/>
      <inertia ixx="9.75e-07" ixy="0" ixz="0"
               iyy="0.000166704" iyz="0" izz="0.000167604"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="revolute">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0.0 -0.1965 -0.0605" rpy="-1.57 -1.57 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1e16" upper="1e16" effort="300" velocity="2"/>
  </joint>

  <link name="right_wheel">
    <visual>
      <geometry>
        <mesh filename="package://qbot_platform/meshes/qbot_platform_wheel.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="Red"/>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.045" length="0.025" />
      </geometry>
    </collision>

    <inertial>
      <mass value="0.005"/>
      <inertia ixx="9.75e-07" ixy="0" ixz="0"
               iyy="0.000166704" iyz="0" izz="0.000167604"/>
    </inertial>
  </link>

  <!-- ========================= Support Casters  =========================-->
  <!--  Front  -->
  <joint name="front_left_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_left_caster"/>
    <origin xyz="0.13 0.13 -0.06" rpy="-1.57 -1.57 0"/>
    <axis xyz="0 0 1"/>
    <!-- <limit lower="-1e16" upper="1e16" effort="300" velocity="2"/> -->
  </joint>

  <link name="front_left_caster">
    <visual>
      <geometry>
        <cylinder radius="0.045" length="0.025" />
      </geometry>
      <material name="Blue"/>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.045" length="0.025" />
      </geometry>
    </collision>

    <inertial>
      <mass value="0.01"/>
      <inertia ixx="9.75e-07" ixy="0" ixz="0"
               iyy="9.75e-07" iyz="0" izz="9.75e-07"/>
    </inertial>
  </link>

  <joint name="front_right_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_right_caster"/>
    <origin xyz="0.13 -0.13 -0.06" rpy="-1.57 -1.57 0"/>
    <axis xyz="0 0 1"/>
    <!-- <limit lower="-1e16" upper="1e16" effort="300" velocity="2"/> -->
  </joint>

  <link name="front_right_caster">      
    <visual>
      <geometry>
        <cylinder radius="0.045" length="0.025" />
      </geometry>
      <material name="Blue"/>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.045" length="0.025" />
      </geometry>
    </collision>

    <inertial>
      <mass value="0.005"/>
      <inertia ixx="9.75e-07" ixy="0" ixz="0"
               iyy="0.000166704" iyz="0" izz="0.000167604"/>
    </inertial>
  </link>


  <!--  Rear  -->

  <joint name="rear_left_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_left_caster"/>
    <origin xyz="-0.13 0.13 -0.06" rpy="-1.57 -1.57 0"/>
    <axis xyz="0 0 1"/>
    <!-- <limit lower="-1e16" upper="1e16" effort="300" velocity="2"/> -->
  </joint>

  <link name="rear_left_caster">
    <visual>
      <geometry>
        <cylinder radius="0.045" length="0.025" />
      </geometry>
      <material name="Blue"/>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.045" length="0.025" />
      </geometry>
    </collision>

    <inertial>
      <mass value="0.005"/>
      <inertia ixx="9.75e-07" ixy="0" ixz="0"
               iyy="0.000166704" iyz="0" izz="0.000167604"/>
    </inertial>
  </link>


  <joint name="rear_right_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_right_caster"/>
    <origin xyz="-0.13 -0.13 -0.06" rpy="-1.57 -1.57 0"/>
    <axis xyz="0 0 1"/>
    <!-- <limit lower="-1e16" upper="1e16" effort="300" velocity="2"/> -->
  </joint>

  <link name="rear_right_caster">
    <visual>
      <geometry>
        <cylinder radius="0.045" length="0.025" />
      </geometry>
      <material name="Blue"/>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.045" length="0.025" />
      </geometry>
    </collision>

    <inertial>
      <mass value="0.005"/>
      <inertia ixx="9.75e-07" ixy="0" ixz="0"
               iyy="0.000166704" iyz="0" izz="0.000167604"/>
    </inertial>
  </link>


</robot>
